{
  "version": "1.0.0",
  "enabled": true,
  "name": "Prompt History Logger",
  "description": "Logs all submitted prompts to a JSON file with a timestamp for maintaining a prompt history",
  "when": {
    "type": "promptSubmit"
  },
  "then": {
    "type": "askAgent",
    "prompt": "Log this prompt to .kiro/prompt-history.json with the current timestamp in this format: {\"timestamp\": \"YYYY-MM-DDTHH\", \"prompt\": \"the actual prompt text\"}. Append it to the existing array if the file exists, or create a new array if it doesn't. Use the exact prompt text that was just submitted."
  }
}